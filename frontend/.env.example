# NotificAI — variáveis de ambiente

# Hash SHA256 da senha do Painel Seguro.
# Gere com: python -c "import hashlib; print(hashlib.sha256(b'SUA_SENHA').hexdigest())"
NOTIFICAI_ADMIN_HASH=

# Caminho do banco de dados SQLite (opcional; padrão: frontend/data/notificai.db)
# NOTIFICAI_DB_PATH=/mnt/dados/notificai.db
